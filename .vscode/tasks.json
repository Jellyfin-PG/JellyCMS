{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Publish Jellyfin Plugin (Debug)",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-Command",
                "dotnet build -c Debug"
            ],
            "problemMatcher": "$msCompile",
