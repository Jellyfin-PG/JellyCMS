{
  "id": "weather-dashboard",
  "name": "Weather Dashboard",
  "category": "Interactive",
  "icon": "partly_cloudy_day",
  "settings": [
    {
      "name": "title",
      "label": "Widget Header Title",
      "type": "text",
      "default": "Local Weather",
